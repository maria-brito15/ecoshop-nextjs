# .env.example

# ============================================
# BANCO DE DADOS
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://usuario:senha@localhost:5432/ecoshop

# Redis connection string
REDIS_URL=redis://localhost:6379

# ============================================
# AUTENTICAÇÃO JWT
# ============================================
# Chave secreta para assinatura dos tokens JWT (mínimo 32 caracteres)
JWT_SECRET=seu-segredo-jwt-aqui-mude-em-producao

# ============================================
# INTELIGÊNCIA ARTIFICIAL
# ============================================
# Google Gemini API key (obter em https://aistudio.google.com/)
GEMINI_KEY=sua-chave-gemini-aqui

# Azure Custom Vision (classificação de imagens)
AZURE_VISION_ENDPOINT=https://seu-recurso.cognitiveservices.azure.com/
AZURE_VISION_KEY=sua-chave-azure-aqui

# Confiança mínima para identificação (0.0 a 1.0, padrão: 0.7)
AI_CONFIDENCE_THRESHOLD=0.7

# ============================================
# URL PÚBLICA DA APLICAÇÃO
# ============================================
# Usado para gerar links em emails, etc. (opcional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# DADOS DO ADMINISTRADOR (SEED)
# ============================================
# Estas variáveis são usadas pelo script prisma/seed-admin.ts
# Apenas para desenvolvimento - NÃO use em produção com valores padrão

# Email do administrador (padrão: admin@ecoshop.com)
ADMIN_EMAIL=admin@ecoshop.com

# Senha do administrador (padrão: Admin@123456)
# Atenção: mínimo 8 caracteres
ADMIN_PASSWORD=Admin@123456

# Nome do administrador (padrão: Administrador EcoShop)
ADMIN_NAME=Administrador EcoShop

# Telefone do administrador (opcional)
ADMIN_PHONE=(11) 99999-8888